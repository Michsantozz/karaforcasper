# Recall.ai — bots de reunião (Zoom/Meet/Teams). Mesma key serve REST e MCP.
# Crie a key no dashboard da região correspondente. Recursos são region-local.
# RECALL_API_KEY=
# RECALL_REGION=us-east-1   # us-west-2 | us-east-1 | eu-central-1 | ap-northeast-1
# Signing secret do endpoint de webhook (Svix). Obrigatório para receber webhooks
# do Recall: as rotas /api/webhooks/recall* recusam (401/500) sem verificação válida.
# Pegue no dashboard do Recall ao criar o webhook endpoint (formato whsec_...).
# Configure DOIS endpoints no dashboard do Recall (mesmo secret Svix):
#   - Calendar events → {APP_URL}/api/webhooks/recall
#   - Bot/transcript   → {APP_URL}/api/webhooks/recall/bot   (gera a ata automática
#     no fim da reunião e notifica o dono; inscreva transcript.done E
#     transcript.failed — sem o failed, uma transcrição que falha na Recall vira
#     reunião fantasma, sem row e sem aviso)
# RECALL_WEBHOOK_SECRET=
# Poll-backfill (safety net p/ webhook perdido) — opcionais, têm default.
# BACKFILL_WINDOW_MS=259200000   # janela de varredura (default 72h); aumente se
#                                # o app puder ficar fora do ar por mais tempo
# BACKFILL_MAX_PAGES=10          # páginas por run (bound de custo); backlog segue
#                                # no próximo tick, com log quando trunca

# Postgres — OBRIGATÓRIO. Drizzle + better-auth + Mastra memory. [SECRET]
# Rode as migrations antes de subir o app: pnpm db:migrate
#
# RLS: no compose o app conecta como a role NÃO-owner `app_user` (as policies
# FORCE ROW LEVEL SECURITY só isolam de fato quando o app NÃO é superuser/owner).
# Fora do compose, aponte DATABASE_URL para uma role sem BYPASSRLS e não-owner.
DATABASE_URL=postgres://user:pass@host:5432/casperagent

# Senha da role `app_user` (a conexão de runtime do app no compose). [SECRET]
# O job app-db-init faz ALTER ROLE app_user LOGIN PASSWORD com este valor; o
# serviço `app` usa app_user:APP_DB_PASSWORD no DATABASE_URL. Use uma senha forte
# e distinta de POSTGRES_PASSWORD (que fica só no owner/superuser `casper`).
APP_DB_PASSWORD=change-me-app-user-password

# E-mail transacional (Resend) — push externo: "ata pronta".
# Opcional: sem RESEND_API_KEY o envio vira no-op (só sino in-app).
# Pegue a key em https://resend.com/api-keys. EMAIL_FROM precisa de domínio
# verificado no Resend; sem domínio, use o sandbox onboarding@resend.dev (só
# entrega para o e-mail da sua própria conta Resend).
# RESEND_API_KEY=re_...
# EMAIL_FROM=CasperAgent <no-reply@seudominio.com>

# Auth (better-auth). Verificação de email antes do login.
# - Em PRODUÇÃO é OBRIGATÓRIA por padrão (com password signup ligado) e exige um
#   provedor de email real (RESEND_API_KEY + EMAIL_FROM) — senão o boot falha.
#   Sem verificação, qualquer um registra um email que não controla.
# - Para opt-out (passwordless-only) em produção, ligue OS DOIS:
#     REQUIRE_EMAIL_VERIFICATION=false
#     PASSWORD_SIGNUP_ENABLED=false
#   Isso desliga o cadastro por senha (sign-in de credenciais existentes segue).
# - Fora de produção o default é off (transporte de email é console.log em dev).
# REQUIRE_EMAIL_VERIFICATION=false
# PASSWORD_SIGNUP_ENABLED=false

# Calendar V2 (multi-usuário). VOCÊ implementa o OAuth do provider; o Recall só
# recebe o refresh_token. Crie o OAuth Client no Google Cloud Console com os
# scopes calendar.events.readonly + userinfo.email e habilite a Calendar API.
# Em "testing" a conexão expira em 7 dias — publique o app pra produção.
# Secret para assinar o `state` do OAuth de calendar (HMAC anti account-linking).
# Obrigatório. Gere com: openssl rand -base64 32
# OAUTH_STATE_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Deve bater EXATO com o Authorized redirect URI cadastrado no Google (seu domínio).
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/calendar/google/callback
# URL pública do app (para montar webhook_url e redirects). Default: origin da request.
# APP_URL=http://localhost:3000

# LLM via AWS Bedrock (model do agente). [SECRET nas keys]
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=  (opcional, se usar credencial temporária)

# ─────────────────────────────────────────────────────────────────────────────
# Deploy / runtime (container, self-host, multi-instância)
# ─────────────────────────────────────────────────────────────────────────────

# Ambiente. Em produção: production (ativa CSP dura + cache).
NODE_ENV=development

# Segredo de criptografia/assinatura do better-auth (cookies de sessão, tokens).
# [SECRET] OBRIGATÓRIO em prod. Sem valor fixo entre réplicas → cada instância
# gera um segredo efêmero e invalida todas as sessões (login quebra em multi-
# instância). base64 de 32 bytes: openssl rand -base64 32
BETTER_AUTH_SECRET=

# URLs públicas do app. better-auth valida origin/callback contra BETTER_AUTH_URL.
# NEXT_PUBLIC_* é inlinado no bundle client em BUILD TIME — setar no build da imagem.
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Chave de criptografia das Server Actions. [SECRET] OBRIGATÓRIA em multi-instância.
# Sem valor fixo entre réplicas → "Failed to find Server Action" intermitente.
# base64 de 32 bytes: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Criptografia dos tokens OAuth de terceiros em repouso (account.access/refresh_token).
# [SECRET] Recomendada em prod: sem ela os tokens Google ficam em PLAINTEXT no
# Postgres (um dump vaza tudo). Ausente → passthrough (dev). 32 bytes base64:
# openssl rand -base64 32
# ACCOUNT_TOKEN_ENCRYPTION_KEY=
# Chave antiga durante rotação (só descriptografa dados gravados com ela).
# ACCOUNT_TOKEN_ENCRYPTION_KEY_FALLBACK=

# Build ID estável (evita version skew em rolling deploy). CI passa o git SHA.
# GIT_HASH=

# Inngest — runtime dos workflows de reunião (crons + eventos). Servido em /api/inngest.
# Em dev use o CLI (sem keys): pnpm dev:inngest -u http://localhost:3000/api/inngest
# Em prod (docker-compose, INNGEST_DEV=0) as DUAS keys são OBRIGATÓRIAS e precisam
# ser IGUAIS no serviço `inngest` e no `app` — senão o handshake app<->inngest e a
# entrega de eventos falham fechado. Gere valores hex: `openssl rand -hex 32`.
# INNGEST_DEV=1                              # modo dev (sem keys)
# INNGEST_BASE_URL=http://inngest:8288       # endpoint do Inngest server em prod
INNGEST_SIGNING_KEY=                         # [SECRET] em prod — hex, par de chars
INNGEST_EVENT_KEY=                           # [SECRET] em prod

# Recall MCP (opcional, além do REST acima). Token e URL do servidor MCP.
# RECALL_MCP_TOKEN=                          # [SECRET]
# RECALL_MCP_URL=

# Auto-schedule (default em código; override se precisar).
# AUTO_SCHEDULE_HORIZON_MINUTES=

# Fireworks AI API key — https://fireworks.ai/account/api-keys
FIREWORKS_API_KEY=your-fireworks-api-key

# Model provider for Mastra agents: fireworks (default) | bedrock
MODEL_PROVIDER=fireworks
# Fireworks model slug (without the fireworks-ai/ prefix).
# kimi-k2p7-code supports vision (image input) — needed for image attachments.
FIREWORKS_MODEL_ID=accounts/fireworks/models/kimi-k2p7-code

# LLM guardrails on the chat agent (PromptInjectionDetector + PIIDetector).
# These are LLM-based, so they add latency + cost per message — off by default.
# Set to "true" in production to BLOCK prompt-injection and REDACT PII on the
# user's last message before it reaches the agent. Recommended for any
# deployment that ingests untrusted meeting transcripts.
ENABLE_LLM_GUARDRAILS=false

# ── Object storage (MinIO / S3) — image + file attachments in chat ──────────
# In docker-compose these are wired to the bundled MinIO service. For an
# external S3/R2, point S3_ENDPOINT at the provider (omit for real AWS S3) and
# fill in real credentials.
#
# Least privilege (fix #8): MINIO_ROOT_* são as credenciais ADMIN do MinIO —
# usadas SÓ pelo serviço minio e pelo job minio-init (que cria bucket + service
# account). O APP usa S3_ACCESS_KEY_ID/S3_SECRET_ACCESS_KEY, que o minio-init
# provisiona como uma service account escopada só ao bucket. Use valores
# DISTINTOS do root; um comprometimento do app não deve dar admin do storage.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin            # [SECRET] em prod — só admin/init
S3_ENDPOINT=http://localhost:9200         # MinIO API (host port; omit for real AWS S3)
S3_REGION=us-east-1
S3_BUCKET=casper-uploads
S3_ACCESS_KEY_ID=casper-app               # service account do app (≠ root)
S3_SECRET_ACCESS_KEY=change-me-app-s3-secret  # [SECRET] em prod
# Public base URL where objects are served (presigned GET; browser/provider fetch here).
S3_PUBLIC_URL=http://localhost:9200/casper-uploads
S3_FORCE_PATH_STYLE=true                  # true for MinIO/R2; false for AWS S3
# Host bind for the MinIO ports (fix #8). Default: loopback only. Em prod,
# remova/neutralize MINIO_CONSOLE_BIND para não publicar o console admin.
# MINIO_API_BIND=127.0.0.1:9200
# MINIO_CONSOLE_BIND=127.0.0.1:9201

# ── Langfuse (opcional) — dashboard de traces + token/custo/latência ────────
# Mastra já emite spans + métricas de token/custo/latência (mastra_model_*,
# estimatedCost, mastra_{agent,tool,workflow}_duration_ms) automaticamente e
# persiste no PG. Preencher as duas keys ADICIONA o LangfuseExporter, que
# manda os mesmos dados pro dashboard navegável. All-or-nothing: ou as duas,
# ou nenhuma. Ausente → traces ficam só no PG (sem mudança de comportamento).
# Crie o par de keys em https://cloud.langfuse.com (ou seu self-host).
# LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx        # public key do projeto Langfuse
# LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx        # [SECRET]
# LANGFUSE_BASE_URL=https://cloud.langfuse.com   # omitir p/ cloud; setar p/ self-host

# ── Sentry (opcional) — error tracking p/ cron/webhook/enrich ───────────────
# Sem DSN o SDK nunca inicializa (no-op puro). Com DSN, erros de route
# handlers / Server Actions / Server Components (via onRequestError) e os
# capturados no api-error.ts vão pro Sentry com grouping + alerta. Crie o
# projeto (Next.js) em sentry.io e copie o DSN. SENTRY_ENVIRONMENT é só tag.
# SENTRY_DSN=https://xxxx@oXXXX.ingest.sentry.io/XXXX   # [SECRET-ish]
# SENTRY_ENVIRONMENT=production                          # default: NODE_ENV

# ── Logging (pino) ──────────────────────────────────────────────────────────
# Verbosidade do logger estruturado. Default `info`. dev usa pino-pretty
# (colorido), prod emite JSON por linha p/ pipeline (Loki/Datadog/CloudWatch).
# fatal|error|warn|info|debug|trace|silent
# LOG_LEVEL=info
