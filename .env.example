# Recall.ai — bots de reunião (Zoom/Meet/Teams). Mesma key serve REST e MCP.
# Crie a key no dashboard da região correspondente. Recursos são region-local.
# RECALL_API_KEY=
# RECALL_REGION=us-east-1   # us-west-2 | us-east-1 | eu-central-1 | ap-northeast-1
# Signing secret do endpoint de webhook (Svix). Obrigatório para receber webhooks
# do Recall: as rotas /api/webhooks/recall* recusam (401/500) sem verificação válida.
# Pegue no dashboard do Recall ao criar o webhook endpoint (formato whsec_...).
# Configure DOIS endpoints no dashboard do Recall (mesmo secret Svix):
#   - Calendar events → {APP_URL}/api/webhooks/recall
#   - Bot/transcript   → {APP_URL}/api/webhooks/recall/bot   (gera a ata automática
#     no fim da reunião e notifica o dono; inscreva o evento transcript.done)
# RECALL_WEBHOOK_SECRET=

# Postgres — OBRIGATÓRIO. Drizzle + better-auth + Mastra memory. [SECRET]
# Rode as migrations antes de subir o app: pnpm db:migrate
DATABASE_URL=postgres://user:pass@host:5432/casperagent

# E-mail transacional (Resend) — push externo: "ata pronta".
# Opcional: sem RESEND_API_KEY o envio vira no-op (só sino in-app).
# Pegue a key em https://resend.com/api-keys. EMAIL_FROM precisa de domínio
# verificado no Resend; sem domínio, use o sandbox onboarding@resend.dev (só
# entrega para o e-mail da sua própria conta Resend).
# RESEND_API_KEY=re_...
# EMAIL_FROM=CasperAgent <no-reply@seudominio.com>

# Auth (better-auth). Exigir verificação de email antes do login — só ative
# quando houver provedor de email (SMTP/Resend/SES) integrado em auth.ts, senão
# o login trava sem meio de verificar. Default: off.
# REQUIRE_EMAIL_VERIFICATION=false

# Calendar V2 (multi-usuário). VOCÊ implementa o OAuth do provider; o Recall só
# recebe o refresh_token. Crie o OAuth Client no Google Cloud Console com os
# scopes calendar.events.readonly + userinfo.email e habilite a Calendar API.
# Em "testing" a conexão expira em 7 dias — publique o app pra produção.
# Secret para assinar o `state` do OAuth de calendar (HMAC anti account-linking).
# Obrigatório. Gere com: openssl rand -base64 32
# OAUTH_STATE_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Deve bater EXATO com o Authorized redirect URI cadastrado no Google (seu domínio).
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/calendar/google/callback
# URL pública do app (para montar webhook_url e redirects). Default: origin da request.
# APP_URL=http://localhost:3000

# LLM via AWS Bedrock (model do agente). [SECRET nas keys]
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=  (opcional, se usar credencial temporária)

# ─────────────────────────────────────────────────────────────────────────────
# Deploy / runtime (container, self-host, multi-instância)
# ─────────────────────────────────────────────────────────────────────────────

# Ambiente. Em produção: production (ativa CSP dura + cache).
NODE_ENV=development

# Segredo de criptografia/assinatura do better-auth (cookies de sessão, tokens).
# [SECRET] OBRIGATÓRIO em prod. Sem valor fixo entre réplicas → cada instância
# gera um segredo efêmero e invalida todas as sessões (login quebra em multi-
# instância). base64 de 32 bytes: openssl rand -base64 32
BETTER_AUTH_SECRET=

# URLs públicas do app. better-auth valida origin/callback contra BETTER_AUTH_URL.
# NEXT_PUBLIC_* é inlinado no bundle client em BUILD TIME — setar no build da imagem.
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Chave de criptografia das Server Actions. [SECRET] OBRIGATÓRIA em multi-instância.
# Sem valor fixo entre réplicas → "Failed to find Server Action" intermitente.
# base64 de 32 bytes: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Build ID estável (evita version skew em rolling deploy). CI passa o git SHA.
# GIT_HASH=

# Inngest — runtime dos workflows de reunião (crons + eventos). Servido em /api/inngest.
# Em dev use o CLI (sem keys): pnpm dev:inngest -u http://localhost:3000/api/inngest
# Em prod (docker-compose, INNGEST_DEV=0) as DUAS keys são OBRIGATÓRIAS e precisam
# ser IGUAIS no serviço `inngest` e no `app` — senão o handshake app<->inngest e a
# entrega de eventos falham fechado. Gere valores hex: `openssl rand -hex 32`.
# INNGEST_DEV=1                              # modo dev (sem keys)
# INNGEST_BASE_URL=http://inngest:8288       # endpoint do Inngest server em prod
INNGEST_SIGNING_KEY=                         # [SECRET] em prod — hex, par de chars
INNGEST_EVENT_KEY=                           # [SECRET] em prod

# Recall MCP (opcional, além do REST acima). Token e URL do servidor MCP.
# RECALL_MCP_TOKEN=                          # [SECRET]
# RECALL_MCP_URL=

# Auto-schedule (default em código; override se precisar).
# AUTO_SCHEDULE_HORIZON_MINUTES=

# Fireworks AI API key — https://fireworks.ai/account/api-keys
FIREWORKS_API_KEY=your-fireworks-api-key

# Model provider for Mastra agents: fireworks (default) | bedrock
MODEL_PROVIDER=fireworks
# Fireworks model slug (without the fireworks-ai/ prefix).
# kimi-k2p7-code supports vision (image input) — needed for image attachments.
FIREWORKS_MODEL_ID=accounts/fireworks/models/kimi-k2p7-code

# ── Object storage (MinIO / S3) — image + file attachments in chat ──────────
# In docker-compose these are wired to the bundled MinIO service. For an
# external S3/R2, point S3_ENDPOINT at the provider (omit for real AWS S3) and
# fill in real credentials.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin            # [SECRET] em prod
S3_ENDPOINT=http://localhost:9200         # MinIO API (host port; omit for real AWS S3)
S3_REGION=us-east-1
S3_BUCKET=casper-uploads
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin           # [SECRET] em prod
# Public base URL where objects are served (browser + vision model fetch here).
S3_PUBLIC_URL=http://localhost:9200/casper-uploads
S3_FORCE_PATH_STYLE=true                  # true for MinIO/R2; false for AWS S3
