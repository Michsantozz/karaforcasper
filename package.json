{
  "name": "casperagent",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "next dev -p 3001",
    "dev:inngest": "npx inngest-cli@latest dev -u http://localhost:3001/api/inngest",
    "build": "next build",
    "bundle:check": "node scripts/check-bundle-budget.mjs",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:unit": "vitest --project unit",
    "test:component": "vitest --project component",
    "test:integration": "vitest --project integration",
    "test:e2e": "playwright test",
    "test:e2e:live": "RUN_LIVE_E2E=1 playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:dev": "DATABASE_URL=postgres://casper:casper@localhost:5433/casperagent drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:setup": "drizzle-kit migrate",
    "dev:up": "docker compose -f docker-compose.dev.yml up -d && pnpm db:migrate:dev",
    "dev:down": "docker compose -f docker-compose.dev.yml down"
  },
